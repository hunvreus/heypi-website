---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Chat agents for your team, with approvals and sandboxed tools." } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="/assets/styles.css" />
		<script is:inline src="/assets/basecoat.min.js" defer></script>
		<script is:inline src="/assets/htmx.min.js" defer></script>
		<script is:inline src="/assets/copy-code.js" defer></script>
	</head>
	<body class="bg-background text-foreground">
		<slot />
		<div id="toaster" class="toaster" data-align="end" data-side="top"></div>
	</body>
</html>
