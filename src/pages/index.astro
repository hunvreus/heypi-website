---
import Site from "@/layouts/Site.astro";
import Logo from "@/components/Logo.astro";
import checkIcon from "lucide-static/icons/check.svg?raw";
import copyIcon from "lucide-static/icons/copy.svg?raw";
import plusIcon from "lucide-static/icons/plus.svg?raw";
import { codeToHtml } from "shiki";

const prompt =
  "Read https://heypi.dev/start.md then help create my first agent.";

const installCommands = [
  {
    id: "npm",
    label: "npm",
    code: "npm create heypi@latest my-agent",
  },
  {
    id: "pnpm",
    label: "pnpm",
    code: "pnpm create heypi@latest my-agent",
  },
  {
    id: "yarn",
    label: "Yarn",
    code: "yarn create heypi my-agent",
  },
  {
    id: "bun",
    label: "Bun",
    code: "bun create heypi my-agent",
  },
];

const highlightedInstallCommands = await Promise.all(
  installCommands.map(async (command) => ({
    ...command,
    html: await codeToHtml(command.code, {
      lang: "bash",
      themes: {
        light: "vesper",
        dark: "vesper",
      },
      defaultColor: false,
    }),
  })),
);

const features = [
  ["Adapters", "Run agents in Slack, Discord, Telegram, or webhook workflows."],
  [
    "Runtime tools",
    "Expose command, file, search, and attachment tools through a scoped runtime.",
  ],
  [
    "Runtime providers",
    "Use built-in just-bash or plug in Docker, Gondolin, or a custom provider.",
  ],
  ["Approvals", "Require human approval before sensitive tools continue."],
  [
    "Audit trail",
    "Persist turns, calls, approvals, results, and failures in SQLite.",
  ],
  [
    "Scoped memory",
    "Keep durable notes scoped by channel, user, thread, adapter, or agent.",
  ],
  ["Skills", "Let agents manage scoped runbooks and reusable instructions."],
  [
    "Secret requests",
    "Collect secrets through encrypted handoff instead of plain chat.",
  ],
  [
    "Scheduling",
    "Run cron jobs and heartbeat follow-ups against explicit targets.",
  ],
  [
    "Admin UI",
    "Inspect chats, calls, approvals, memory, jobs, runs, and configuration.",
  ],
  [
    "Attachments",
    "Let agents receive files and attach generated files back to chat.",
  ],
  [
    "Custom tools",
    "Add trusted TypeScript tools for your app, data, APIs, and workflows.",
  ],
];

const faqs = [
  {
    question: "What is heypi?",
    answer:
      'heypi is a TypeScript framework for running <a href="https://pi.dev">Pi</a> agents in Slack, Discord, Telegram, and webhook workflows. It gives the agent chat adapters, scoped runtime tools, durable state, approvals, memory, skills, secrets, jobs, and an admin UI.',
  },
  {
    question: "How do I use heypi?",
    answer:
      "Run <code>npm create heypi@latest</code>. It scaffolds a TypeScript app, prompts for adapter, runtime, and model, writes starter agent files, and prepares environment placeholders. You can still build the same app manually with <code>createHeypi()</code>, <code>agentFrom()</code>, and an adapter.",
  },
  {
    question: "What can I connect it to?",
    answer:
      'The core package supports <a href="/docs/adapters/slack">Slack</a>, <a href="/docs/adapters/discord">Discord</a>, <a href="/docs/adapters/telegram">Telegram</a>, and <a href="/docs/adapters/webhook">webhooks</a>. You can also write custom adapters through the <a href="/docs/guides/integrations">integration APIs</a>.',
  },
  {
    question: "Which models can I use?",
    answer:
      'heypi delegates model calls to Pi. Configure the model in <a href="/docs/configuration/agent">agent configuration</a> and provide provider credentials, such as <code>OPENAI_API_KEY</code>, through the Node process environment.',
  },
  {
    question: "Do I need Docker or a VM?",
    answer:
      'No. The default runtime is just-bash. Use <a href="/docs/configuration/runtime">Docker or Gondolin runtime providers</a> when the agent needs a real container or VM boundary, native binaries, package installs, or a workspace that behaves more like Linux.',
  },
  {
    question: "Can agents ask before acting?",
    answer:
      'Yes. Tool calls can require approval before they continue. heypi records who requested the action, who approved it, what ran, and how it ended. See <a href="/docs/configuration/tools">tools and confirmations</a>.',
  },
  {
    question: "What does heypi store?",
    answer:
      "Your heypi app stores data on your own server. By default, chat history, tool calls, approvals, jobs, and admin metadata are saved in SQLite. Files created or received by the agent, including attachments, memory, skills, and saved secrets, live as files in the app workspace. <code>heypi.dev</code> is only the website and docs.",
  },
  {
    question: "How much does heypi cost?",
    answer:
      "heypi is free and open source. You still pay for your own infrastructure, model provider, chat platform, and any external runtime provider you choose.",
  },
  {
    question: "Is heypi open source?",
    answer:
      'Yes. The code is on <a href="https://github.com/hunvreus/heypi">GitHub</a>, packages are published on npm, and the license is in the <a href="https://github.com/hunvreus/heypi/blob/main/LICENSE">repository</a>.',
  },
  {
    question: "Who built this?",
    answer:
      'heypi is built by <a href="https://ronanberder.com">Ronan Berder</a>.',
  },
  {
    question: "Why did you build this?",
    answer:
      "Local, capability-first agents are useful, but team chat needs extra controls: channel adapters, scoped context, runtime boundaries, approvals, audit logs, secret handoff, and operations. heypi packages those pieces around Pi.",
  },
  {
    question: "How can I help?",
    answer:
      '<a href="https://github.com/hunvreus/heypi">Star the project</a>, <a href="https://github.com/hunvreus/heypi/issues">report issues</a>, <a href="https://github.com/hunvreus/heypi/pulls">send pull requests</a>, or <a href="https://github.com/sponsors/hunvreus">sponsor development</a>.',
  },
];
---

<Site
  title="heypi"
  description="AI assistants for team chat, with sandboxed commands and approval flows."
>
  <div class="min-h-screen bg-background text-foreground">
    <div
      class="mx-auto min-h-screen w-full max-w-[960px] bg-background min-[960px]:border-x"
    >
      <header
        class="sticky top-0 z-10 flex h-16 items-center justify-between border-b bg-background px-6"
      >
        <a href="/" class="flex items-center" aria-label="heypi">
          <Logo />
        </a>
        <nav class="flex items-center gap-1 text-muted-foreground">
          <a class="btn-lg-ghost hidden sm:inline-flex" href="/">Home</a>
          <a class="btn-lg-ghost" href="/docs">Docs</a>
          <a
            class="btn-lg-ghost hidden sm:inline-flex"
            href="https://github.com/hunvreus/heypi"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <a
            class="btn-lg-ghost hidden sm:inline-flex"
            href="https://discord.com/channels/1508147316710703215/1511161118385635429"
            target="_blank"
            rel="noopener noreferrer">Discord</a
          >
          <a class="btn-lg-primary" href="/docs/quickstart">Quickstart</a>
        </nav>
      </header>

      <main>
        <section class="border-b p-6 sm:p-16">
          <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            Multiplayer AI agents for your team.
          </h1>
          <p class="mt-4 text-muted-foreground sm:text-lg">
            heypi is a lightweight framework to create AI assistants that
            interact with your whole team on Slack, Discord, etc. It keeps
            things safe with sandboxed commands and approval flows for sensitive
            actions.
          </p>
          <div class="tabs mt-8 w-full" id="landing-install">
            <nav
              role="tablist"
              aria-orientation="horizontal"
              data-variant="line"
            >
              {
                highlightedInstallCommands.map((command, index) => (
                  <button
                    type="button"
                    role="tab"
                    id={`${command.id}-install-tab`}
                    aria-controls={`${command.id}-install-panel`}
                    aria-selected={index === 0 ? "true" : "false"}
                    tabindex={index === 0 ? "0" : "-1"}
                  >
                    {command.label}
                  </button>
                ))
              }
            </nav>
            {
              highlightedInstallCommands.map((command, index) => (
                <div
                  role="tabpanel"
                  id={`${command.id}-install-panel`}
                  aria-labelledby={`${command.id}-install-tab`}
                  tabindex="-1"
                  aria-selected={index === 0 ? "true" : "false"}
                  hidden={index !== 0}
                >
                  <div
                    class="landing-code scrollbar overflow-x-auto bg-muted"
                    set:html={command.html}
                  />
                </div>
              ))
            }
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="btn-lg" href="/docs/quickstart#step-2-fill-in-env">
              Configure agent
            </a>
            <button type="button" class="btn-lg-outline" data-copy-prompt={prompt}>
              <span
                class="[&>svg]:size-3.5"
                data-copy-icon
                set:html={copyIcon}
              />
              <span
                class="hidden [&>svg]:size-3.5"
                data-check-icon
                set:html={checkIcon}
              />
              <span data-copy-label>Copy agent prompt</span>
            </button>
          </div>
        </section>

        <section class="border-b p-6 sm:p-16">
          <div class="feature-grid grid sm:grid-cols-2 md:grid-cols-3">
            {
              features.map(([title, description]) => (
                <div>
                  <h3 class="font-medium">{title}</h3>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">
                    {description}
                  </p>
                </div>
              ))
            }
          </div>
          <a class="btn-lg-outline mt-8" href="/docs">Read docs →</a>
        </section>

        <section class="border-b p-6 sm:p-16">
          <h2 class="text-lg font-semibold">FAQ</h2>
          <section
            class="accordion mt-6 [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-muted-foreground/50 [&_a]:transition-all [&_a]:hover:decoration-foreground/50"
          >
            {
              faqs.map((faq) => (
                <details class="group border-b last:border-b-0">
                  <summary class="w-full rounded-md outline-none transition-all focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50">
                    <span class="flex flex-1 items-start justify-between gap-4 py-4 text-left text-sm font-medium hover:underline">
                      {faq.question}
                      <span
                        class="pointer-events-none shrink-0 translate-y-0.5 text-muted-foreground transition-transform duration-200 group-open:rotate-45 [&>svg]:size-4"
                        set:html={plusIcon}
                      />
                    </span>
                  </summary>
                  <section class="pb-4">
                    <p
                      class="text-sm leading-7 text-muted-foreground"
                      set:html={faq.answer}
                    />
                  </section>
                </details>
              ))
            }
          </section>
        </section>
      </main>
    </div>
    <footer
      class="mx-auto max-w-[960px] px-7 py-9 text-center text-sm text-muted-foreground"
    >
      <p>
        © Ronan Berder
        <a
          class="ml-4 hover:text-foreground"
          href="https://github.com/hunvreus/heypi/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer">License</a
        >
      </p>
    </footer>
  </div>

  <script>
    async function writeLandingClipboard(text: string) {
      if (window.isSecureContext && navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(text);
          return;
        } catch (_) {}
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.top = "-9999px";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();
      const ok = document.execCommand("copy");
      textarea.remove();
      if (!ok) throw new Error("Copy failed");
    }

    function showPromptCopiedToast() {
      const title = "Prompt copied";
      const description =
        "Paste the prompt in your coding agent (Claude Code, Codex, etc) to start building your heypi agent.";
      const duration = 6000;

      try {
        document.dispatchEvent(
          new CustomEvent("basecoat:toast", {
            detail: {
              config: {
                category: null,
                duration,
                title,
                description,
                cancel: {
                  label: "Ok",
                },
              },
            },
          }),
        );
        return;
      } catch (_) {}

      const toaster = document.getElementById("toaster");
      if (!toaster) return;

      const toast = document.createElement("div");
      toast.className = "toast";
      toast.setAttribute("role", "status");
      toast.setAttribute("aria-atomic", "true");
      toast.innerHTML = `
        <div class="toast-content">
          <section>
            <h2>${title}</h2>
            <p>${description}</p>
          </section>
          <footer>
            <button type="button" class="btn" data-toast-cancel>Ok</button>
          </footer>
        </div>
      `;
      toaster.appendChild(toast);
      const dismissToast = () => {
        toast.setAttribute("aria-hidden", "true");
        toast.addEventListener("transitionend", () => toast.remove(), {
          once: true,
        });
      };
      toast
        .querySelector("[data-toast-cancel]")
        ?.addEventListener("click", dismissToast);
      window.setTimeout(dismissToast, duration);
    }

    async function copyLandingPrompt(button: HTMLElement) {
      const copyIcon = button.querySelector("[data-copy-icon]");
      const checkIcon = button.querySelector("[data-check-icon]");
      const showCopied = () => {
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
      };
      const showDefault = () => {
        checkIcon?.classList.add("hidden");
        copyIcon?.classList.remove("hidden");
      };
      try {
        await writeLandingClipboard(button.dataset.copyPrompt || "");
        showCopied();
        showPromptCopiedToast();
      } catch (_) {
        showDefault();
      }
      setTimeout(showDefault, 1500);
    }

    document
      .querySelectorAll<HTMLElement>("[data-copy-prompt]")
      .forEach((button) => {
        if (button.dataset.copyPromptInitialized === "true") return;
        button.dataset.copyPromptInitialized = "true";
        button.addEventListener("click", () => copyLandingPrompt(button));
      });
  </script>

  <script is:inline>
    (() => {
      const accordions = document.querySelectorAll(".accordion");
      accordions.forEach((accordion) => {
        accordion.addEventListener("click", (event) => {
          const summary = event.target.closest("summary");
          if (!summary) return;
          const details = summary.closest("details");
          if (!details) return;
          accordion.querySelectorAll("details").forEach((detailsEl) => {
            if (detailsEl !== details) detailsEl.removeAttribute("open");
          });
        });
      });
    })();
  </script>

  <style>
    .landing-code :global(pre.shiki) {
      margin: 0;
      border-radius: 0;
      background: transparent !important;
    }

    .landing-code :global(pre.shiki code) {
      display: block;
      min-width: max-content;
      padding: 0.75rem;
    }

    @media (min-width: 40rem) {
      .landing-code :global(pre.shiki code) {
        padding: 1rem;
      }
    }

    .feature-grid > * {
      padding: 1rem 0;
      border-top: 1px solid var(--border);
      border-left: 0;
    }

    .feature-grid > :first-child {
      padding-top: 0;
      border-top: 0;
    }

    .feature-grid > :last-child {
      padding-bottom: 0;
    }

    @media (min-width: 40rem) {
      .feature-grid > * {
        padding: 1rem;
        border-top: 1px solid var(--border);
        border-left: 0;
      }

      .feature-grid > :nth-child(-n + 2) {
        padding-top: 0;
        border-top: 0;
      }

      .feature-grid > :nth-last-child(-n + 2) {
        padding-bottom: 0;
      }

      .feature-grid > :nth-child(2n + 1) {
        padding-left: 0;
        border-left: 0;
      }

      .feature-grid > :nth-child(2n) {
        padding-right: 0;
        border-left: 1px solid var(--border);
      }
    }

    @media (min-width: 48rem) {
      .feature-grid > :nth-child(n) {
        padding: 1rem;
        border-top: 1px solid var(--border);
        border-left: 1px solid var(--border);
      }

      .feature-grid > :nth-child(-n + 3) {
        padding-top: 0;
        border-top: 0;
      }

      .feature-grid > :nth-last-child(-n + 3) {
        padding-bottom: 0;
      }

      .feature-grid > :nth-child(3n + 1) {
        padding-left: 0;
        border-left: 0;
      }

      .feature-grid > :nth-child(3n) {
        padding-right: 0;
      }
    }
  </style>
</Site>
