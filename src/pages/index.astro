---
import Site from "@/layouts/Site.astro";
import Logo from "@/components/Logo.astro";
import checkIcon from "lucide-static/icons/check.svg?raw";
import copyIcon from "lucide-static/icons/copy.svg?raw";
import plusIcon from "lucide-static/icons/plus.svg?raw";
import { codeToHtml } from "shiki";

const prompt =
  "Read https://heypi.dev/start.md then help create my first agent.";

const installCommands = [
  {
    id: "npm",
    label: "npm",
    code: "npm create heypi@latest -- codex-tag my-agent",
  },
  {
    id: "pnpm",
    label: "pnpm",
    code: "pnpm create heypi@latest codex-tag my-agent",
  },
  {
    id: "yarn",
    label: "Yarn",
    code: "yarn create heypi codex-tag my-agent",
  },
  {
    id: "bun",
    label: "Bun",
    code: "bun create heypi codex-tag my-agent",
  },
];

const highlightedInstallCommands = await Promise.all(
  installCommands.map(async (command) => ({
    ...command,
    html: await codeToHtml(command.code, {
      lang: "bash",
      themes: {
        light: "min-light",
        dark: "min-dark",
      },
      defaultColor: false,
    }),
  })),
);

const agentTree = await codeToHtml(
  `my-agent/
├─ index.ts
└─ agent/
   ├─ instructions.md
   ├─ tools/
   ├─ skills/
   └─ schedules/`,
  {
    lang: "text",
    themes: { light: "min-light", dark: "min-dark" },
    defaultColor: false,
  },
);

const features = [
  [
    "Chat platforms",
    "Add Slack, Discord, Telegram, or a trusted webhook. One agent, shared by everyone.",
  ],
  [
    "Approvals",
    "Gate sensitive actions behind human approval, with named approvers for your team.",
  ],
  [
    "Audit trail",
    "Inspect durable conversation events, approvals, schedule runs, and Pi session transcripts.",
  ],
  [
    "Files & commands",
    "Let the agent read and write files, run commands, and search a scoped workspace.",
  ],
  [
    "Sandboxing",
    "Use host or Docker execution, or plug in Gondolin, just-bash, Vercel, Cloudflare, or a custom runtime.",
  ],
  [
    "Memory",
    "Store curated durable notes and retrieve them only when they are useful.",
  ],
  [
    "Skills",
    "Stage runbooks, scripts, and assets that Pi can load on demand.",
  ],
  [
    "Secrets",
    "Collect credentials through an encrypted handoff, never pasted in chat.",
  ],
  [
    "Scheduling",
    "Run code-owned cron schedules as isolated prompts or dispatch into a configured conversation.",
  ],
  [
    "File attachments",
    "Receive files from chat and send generated files back.",
  ],
  [
    "Admin panel",
    "Inspect conversations, approvals, active work, Pi sessions, schedules, and secret requests.",
  ],
  [
    "Custom tools",
    "Add trusted TypeScript tools for your own apps, data, and APIs.",
  ],
];

const faqs = [
  {
    question: "What is heypi?",
    answer:
      'heypi is a TypeScript framework for multiplayer chat agents: one <a href="https://pi.dev">Pi</a> agent your whole team uses in Slack, Discord, Telegram, and trusted webhook entrypoints, with approvals, audit trails, scoped runtime tools, memory, secrets, schedules, and an admin UI.',
  },
  {
    question: "How do I use heypi?",
    answer:
      "Run <code>npm create heypi@latest -- codex-tag my-agent</code>. It copies the Codex Tag template, installs its dependencies, and gives you a working agent to configure. You can also build manually with <code>loadAgent()</code>, <code>runHeypi()</code>, and an adapter.",
  },
  {
    question: "Is heypi a workflow platform?",
    answer:
      "No. heypi is optimized for chat-ops agents with governed tool access. It records interrupted work during startup recovery, but it does not replay arbitrary in-flight agent turns after a process crash.",
  },
  {
    question: "What can I connect it to?",
    answer:
      'The core package supports Slack, Discord, Telegram, local, and webhook adapters. See <a href="/docs/adapters/">adapters</a>, or write another transport with the <a href="/docs/guides/custom-adapters/">custom adapter guide</a>.',
  },
  {
    question: "Which models can I use?",
    answer:
      'heypi delegates model calls to Pi. Configure the model in <a href="/docs/configuration/#agent">agent configuration</a> and provide provider credentials, such as <code>OPENAI_API_KEY</code>, through the Node process environment.',
  },
  {
    question: "Do I need Docker or a VM?",
    answer:
      'No. Host execution is enough for many agents. Use Docker, Gondolin, Vercel, Cloudflare, or a custom <a href="/docs/guides/custom-runtimes/">runtime provider</a> when the agent needs a real container or remote execution boundary.',
  },
  {
    question: "Can agents ask before acting?",
    answer:
      'Yes. Tool calls can require approval before they continue. heypi records who requested the action, who approved it, what ran, and how it ended. See <a href="/docs/guides/custom-tools/#side-effects-and-approvals">tool approvals</a>.',
  },
  {
    question: "What does heypi store?",
    answer:
      "Your heypi app stores its state on your own infrastructure. heypi keeps append-only conversation and audit records, schedule state, workspaces, and encrypted secret handoffs under its configured state directory, while Pi owns its session transcripts. <code>heypi.dev</code> is only the website and docs.",
  },
  {
    question: "How much does heypi cost?",
    answer:
      "heypi is free and open source. You still pay for your own infrastructure, model provider, chat platform, and any external runtime provider you choose.",
  },
  {
    question: "Is heypi open source?",
    answer:
      'Yes. The code is on <a href="https://github.com/hunvreus/heypi">GitHub</a>, packages are published on npm, and the license is in the <a href="https://github.com/hunvreus/heypi/blob/main/LICENSE">repository</a>.',
  },
  {
    question: "Who built this?",
    answer:
      'heypi is built by <a href="https://ronanberder.com">Ronan Berder</a>.',
  },
  {
    question: "Why did you build this?",
    answer:
      "Most AI assistants are single-player: one person, one private chat. Teams need something different. A shared agent in a shared channel needs channel adapters, scoped context, runtime boundaries, approvals, audit logs, and secret handoff. heypi packages those pieces around Pi.",
  },
  {
    question: "How can I help?",
    answer:
      '<a href="https://github.com/hunvreus/heypi">Star the project</a>, <a href="https://github.com/hunvreus/heypi/issues">report issues</a>, <a href="https://github.com/hunvreus/heypi/pulls">send pull requests</a>, or <a href="https://github.com/sponsors/hunvreus">sponsor development</a>.',
  },
];
---

<Site
  title="heypi"
  description="A multiplayer chat agent for your team. One AI agent in Slack, Discord, and Telegram, with approvals, an audit trail, and sandboxed tools."
>
  <div class="min-h-screen bg-background text-foreground">
    <div
      class="mx-auto min-h-screen w-full max-w-[960px] bg-background min-[960px]:border-x"
    >
      <header
        class="sticky top-0 z-10 flex h-16 items-center justify-between border-b bg-background px-6"
      >
        <a
          href="/"
          class="flex items-center text-heading-foreground"
          aria-label="heypi"
        >
          <Logo />
        </a>
        <nav class="flex items-center gap-1 text-muted-foreground">
          <a class="btn hidden sm:inline-flex" data-variant="ghost" href="/">Home</a>
          <a class="btn" data-variant="ghost" href="/docs">Docs</a>
          <a
            class="btn hidden sm:inline-flex"
            data-variant="ghost"
            href="https://github.com/hunvreus/heypi"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
          <a
            class="btn hidden sm:inline-flex"
            data-variant="ghost"
            href="https://heypi.dev/chat"
            target="_blank"
            rel="noopener noreferrer">Discord</a
          >
          <a class="btn" data-size="lg" href="/docs/getting-started/">Quickstart</a>
        </nav>
      </header>

      <main>
        <section class="border-b p-6 sm:p-16">
          <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
            A multiplayer chat agent for your team.
          </h1>
          <p class="mt-4 text-muted-foreground sm:text-lg">
            Most AI assistants are single-player. heypi puts one agent in your
            team's Slack, Discord, or Telegram, with sandboxed tools, approvals,
            and an audit trail for anything sensitive. An app you own, not a
            workflow platform.
          </p>
          <div class="tabs mt-8 w-full" id="landing-install">
            <nav
              role="tablist"
              aria-orientation="horizontal"
              data-variant="line"
            >
              {
                highlightedInstallCommands.map((command, index) => (
                  <button
                    type="button"
                    role="tab"
                    id={`${command.id}-install-tab`}
                    aria-controls={`${command.id}-install-panel`}
                    aria-selected={index === 0 ? "true" : "false"}
                    tabindex={index === 0 ? "0" : "-1"}
                  >
                    {command.label}
                  </button>
                ))
              }
            </nav>
            {
              highlightedInstallCommands.map((command, index) => (
                <div
                  role="tabpanel"
                  id={`${command.id}-install-panel`}
                  aria-labelledby={`${command.id}-install-tab`}
                  tabindex="-1"
                  aria-selected={index === 0 ? "true" : "false"}
                  hidden={index !== 0}
                >
                  <div
                    class="landing-code scrollbar overflow-x-auto bg-muted"
                    set:html={command.html}
                  />
                </div>
              ))
            }
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="btn" data-size="lg" href="/docs/getting-started/#create-an-agent">
              Configure agent
            </a>
            <button
              type="button"
              class="btn"
              data-variant="outline"
              data-size="lg"
              data-copy-prompt={prompt}
            >
              <span
                class="[&>svg]:size-3.5"
                data-copy-icon
                set:html={copyIcon}
              />
              <span
                class="hidden [&>svg]:size-3.5"
                data-check-icon
                set:html={checkIcon}
              />
              <span data-copy-label>Copy agent prompt</span>
            </button>
          </div>
        </section>

        <section class="border-b p-6 sm:p-16">
          <h2 class="text-lg font-semibold">Your agent is just files</h2>
          <p class="mt-2 max-w-2xl text-muted-foreground">
            No dashboard to configure. An agent is a folder you edit and commit
            to git. The scaffolder writes it for you.
          </p>
          <div class="mt-8 grid gap-8 md:grid-cols-2 md:items-center">
            <div
              class="landing-code scrollbar overflow-x-auto bg-muted"
              data-copy-code="false"
              set:html={agentTree}
            />
            <ul
              class="grid content-start gap-3 text-sm leading-6 text-muted-foreground"
            >
              <li>
                <strong class="font-medium text-foreground"
                  >instructions.md</strong
                >: who the agent is and how it behaves.
              </li>
              <li>
                <strong class="font-medium text-foreground">tools/</strong>:
                TypeScript functions it can call.
              </li>
              <li>
                <strong class="font-medium text-foreground">skills/</strong>:
                runbooks it can follow on demand.
              </li>
              <li>
                <strong class="font-medium text-foreground">schedules/</strong>:
                scheduled and recurring work.
              </li>
              <li>
                <strong class="font-medium text-foreground">index.ts</strong>:
                chat platforms, runtime, and state.
              </li>
            </ul>
          </div>
        </section>

        <section class="border-b p-6 sm:p-16">
          <h2 class="text-lg font-semibold">Everything a shared agent needs</h2>
          <p class="mt-2 max-w-2xl text-muted-foreground">
            heypi wraps a Pi agent with what a team actually needs: a place in
            chat, governed tools, durable state, and a record of everything it
            does.
          </p>
          <div class="feature-grid mt-8 grid sm:grid-cols-2 md:grid-cols-3">
            {
              features.map(([title, description]) => (
                <div>
                  <h3 class="font-medium">{title}</h3>
                  <p class="mt-1 text-sm leading-6 text-muted-foreground">
                    {description}
                  </p>
                </div>
              ))
            }
          </div>
          <a class="btn mt-8" data-variant="outline" data-size="lg" href="/docs">Read docs →</a>
        </section>

        <section class="border-b p-6 sm:p-16">
          <h2 class="text-lg font-semibold">FAQ</h2>
          <section
            class="accordion mt-6 [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-muted-foreground/50 [&_a]:transition-all [&_a]:hover:decoration-foreground/50"
          >
            {
              faqs.map((faq) => (
                <details class="group border-b last:border-b-0">
                  <summary>
                    {faq.question}
                    <span
                      class="text-muted-foreground transition-transform duration-200 group-open:rotate-45 [&>svg]:size-4"
                      set:html={plusIcon}
                    />
                  </summary>
                  <section class="pb-4">
                    <p
                      class="text-sm leading-7 text-muted-foreground"
                      set:html={faq.answer}
                    />
                  </section>
                </details>
              ))
            }
          </section>
        </section>
      </main>
    </div>
    <footer
      class="mx-auto max-w-[960px] px-7 py-9 text-center text-sm text-muted-foreground"
    >
      <p>
        © Ronan Berder
        <a
          class="ml-4 hover:text-foreground"
          href="https://github.com/hunvreus/heypi/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer">License</a
        >
      </p>
    </footer>
  </div>

  <script>
    async function writeLandingClipboard(text: string) {
      if (window.isSecureContext && navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(text);
          return;
        } catch (_) {}
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.top = "-9999px";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();
      const ok = document.execCommand("copy");
      textarea.remove();
      if (!ok) throw new Error("Copy failed");
    }

    function showPromptCopiedToast() {
      const title = "Prompt copied";
      const description =
        "Paste the prompt in your coding agent (Claude Code, Codex, etc) to start building your heypi agent.";
      const duration = 6000;

      const toaster = document.getElementById("toaster");
      if (toaster && "toast" in toaster) {
        toaster.toast({
          category: null,
          duration,
          title,
          description,
          cancel: {
            label: "Ok",
          },
        });
        return;
      }

      if (!toaster) return;

      const toast = document.createElement("div");
      toast.className = "toast";
      toast.setAttribute("role", "status");
      toast.setAttribute("aria-atomic", "true");
      toast.innerHTML = `
        <div class="toast-content">
          <section>
            <h2>${title}</h2>
            <p>${description}</p>
          </section>
          <footer>
            <button type="button" class="btn" data-toast-cancel>Ok</button>
          </footer>
        </div>
      `;
      toaster.appendChild(toast);
      const dismissToast = () => {
        toast.setAttribute("aria-hidden", "true");
        toast.addEventListener("transitionend", () => toast.remove(), {
          once: true,
        });
      };
      toast
        .querySelector("[data-toast-cancel]")
        ?.addEventListener("click", dismissToast);
      window.setTimeout(dismissToast, duration);
    }

    async function copyLandingPrompt(button: HTMLElement) {
      const copyIcon = button.querySelector("[data-copy-icon]");
      const checkIcon = button.querySelector("[data-check-icon]");
      const showCopied = () => {
        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
      };
      const showDefault = () => {
        checkIcon?.classList.add("hidden");
        copyIcon?.classList.remove("hidden");
      };
      try {
        await writeLandingClipboard(button.dataset.copyPrompt || "");
        showCopied();
        showPromptCopiedToast();
      } catch (_) {
        showDefault();
      }
      setTimeout(showDefault, 1500);
    }

    document
      .querySelectorAll<HTMLElement>("[data-copy-prompt]")
      .forEach((button) => {
        if (button.dataset.copyPromptInitialized === "true") return;
        button.dataset.copyPromptInitialized = "true";
        button.addEventListener("click", () => copyLandingPrompt(button));
      });
  </script>

  <style>
    .landing-code :global(pre.shiki) {
      margin: 0;
      border-radius: 0;
      background: transparent !important;
    }

    .landing-code :global(pre.shiki code) {
      display: block;
      min-width: max-content;
      padding: 0.75rem;
    }

    @media (min-width: 40rem) {
      .landing-code :global(pre.shiki code) {
        padding: 1rem;
      }
    }

    .feature-grid > * {
      padding: 1rem 0;
      border-top: 1px solid var(--border);
      border-left: 0;
    }

    .feature-grid > :first-child {
      padding-top: 0;
      border-top: 0;
    }

    .feature-grid > :last-child {
      padding-bottom: 0;
    }

    @media (min-width: 40rem) {
      .feature-grid > * {
        padding: 1rem;
        border-top: 1px solid var(--border);
        border-left: 0;
      }

      .feature-grid > :nth-child(-n + 2) {
        padding-top: 0;
        border-top: 0;
      }

      .feature-grid > :nth-last-child(-n + 2) {
        padding-bottom: 0;
      }

      .feature-grid > :nth-child(2n + 1) {
        padding-left: 0;
        border-left: 0;
      }

      .feature-grid > :nth-child(2n) {
        padding-right: 0;
        border-left: 1px solid var(--border);
      }
    }

    @media (min-width: 48rem) {
      .feature-grid > :nth-child(n) {
        padding: 1rem;
        border-top: 1px solid var(--border);
        border-left: 1px solid var(--border);
      }

      .feature-grid > :nth-child(-n + 3) {
        padding-top: 0;
        border-top: 0;
      }

      .feature-grid > :nth-last-child(-n + 3) {
        padding-bottom: 0;
      }

      .feature-grid > :nth-child(3n + 1) {
        padding-left: 0;
        border-left: 0;
      }

      .feature-grid > :nth-child(3n) {
        padding-right: 0;
      }
    }
  </style>
</Site>
