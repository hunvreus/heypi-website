---
import Site from "@/layouts/Site.astro";
---

<Site
	title="Page not found"
	description="The requested heypi page could not be found."
	robots="noindex, follow"
>
	<main class="flex min-h-screen flex-col bg-background text-foreground">
		<section class="empty flex-1">
			<header>
				<h3>404 - Not Found</h3>
				<p>This page does not exist, moved, or is not part of the published heypi docs.</p>
			</header>
			<footer>
				<div class="flex gap-2">
					<a href="/" class="btn">Go home</a>
					<a href="/docs" class="btn" data-variant="outline">Open docs</a>
				</div>
			</footer>
		</section>
	</main>
</Site>
