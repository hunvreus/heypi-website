---
import Site from "@/layouts/Site.astro";
import Logo from "@/components/Logo.astro";
---

<Site
	title="Page not found"
	description="The requested heypi page could not be found."
	robots="noindex, follow"
>
	<main class="flex min-h-screen flex-col bg-background text-foreground">
		<header class="border-b border-border/60">
			<div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
				<a href="/" aria-label="heypi home" class="inline-flex items-center">
					<Logo class="h-7 w-auto" />
				</a>
				<nav class="flex items-center gap-2 text-sm text-muted-foreground">
					<a href="/docs" class="rounded-md px-2 py-1.5 transition-colors hover:bg-muted hover:text-foreground">Docs</a>
					<a href="https://github.com/hunvreus/heypi" class="rounded-md px-2 py-1.5 transition-colors hover:bg-muted hover:text-foreground">GitHub</a>
				</nav>
			</div>
		</header>

		<section class="mx-auto flex w-full max-w-6xl flex-1 items-center px-4 py-16 sm:px-6">
			<div class="max-w-2xl">
				<p class="text-sm font-medium text-muted-foreground">404</p>
				<h1 class="mt-4 text-4xl font-semibold tracking-tight text-heading-foreground sm:text-5xl">
					Page not found
				</h1>
				<p class="mt-5 max-w-xl text-base leading-7 text-muted-foreground">
					This page does not exist, moved, or is not part of the published heypi docs.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a href="/" class="btn-primary">Go home</a>
					<a href="/docs" class="btn-secondary">Open docs</a>
				</div>
			</div>
		</section>
	</main>
</Site>
